<!DOCTYPE html>
<html>
<%- include('../partials/head', { title: 'Lecciones' }) %>
<body>
<%- include('../partials/navbar') %>
<div class="container my-5">
    <div class="card p-4">
        <div class="top-actions mb-4">
            <div>
                <h1 class="page-title mb-1">Lecciones</h1>
                <p class="text-muted mb-0">Lista de lecciones con curso asociado.</p>
            </div>
            <a href="/lecciones/create" class="btn btn-success">Nueva Leccion</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Titulo</th>
                        <th>Video</th>
                        <th>Curso</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (lecciones.length === 0) { %>
                        <tr>
                            <td colspan="5" class="text-center py-4">No hay lecciones registradas.</td>
                        </tr>
                    <% } %>
                    <% lecciones.forEach(leccion => { %>
                        <tr>
                            <td><%= leccion.id_leccion %></td>
                            <td><%= leccion.titulo %></td>
                            <td><a href="<%= leccion.video_url %>" target="_blank" class="link-primary"><%= leccion.video_url || 'Sin URL' %></a></td>
                            <td><span class="badge bg-primary"><%= leccion.curso %></span></td>
                            <td class="text-end">
                                <a href="/lecciones/edit/<%= leccion.id_leccion %>" class="btn btn-sm btn-outline-primary">Editar</a>
                                <a href="/lecciones/delete/<%= leccion.id_leccion %>" class="btn btn-sm btn-outline-danger">Eliminar</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<%- include('../partials/footer') %>
</body>
</html>
