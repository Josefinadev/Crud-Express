<!DOCTYPE html>
<html>
<%- include('../partials/head', { title: 'Crear Leccion' }) %>
<body>
<%- include('../partials/navbar') %>
<div class="container my-5">
    <div class="card p-4 mx-auto" style="max-width: 720px;">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="page-title mb-1">Crear Leccion</h1>
                <p class="text-muted">Registra una nueva leccion y asciala a un curso existente.</p>
            </div>
            <a href="/lecciones" class="btn btn-outline-secondary">Volver</a>
        </div>
        <form action="/lecciones/store" method="POST">
            <div class="mb-3">
                <label class="form-label">Titulo</label>
                <input type="text" name="titulo" class="form-control" placeholder="Titulo" required>
            </div>
            <div class="mb-3">
                <label class="form-label">URL del video</label>
                <input type="text" name="video_url" class="form-control" placeholder="https://...">
            </div>
            <div class="mb-4">
                <label class="form-label">Curso asociado</label>
                <select class="form-select" name="id_curso" required>
                    <% cursos.forEach(curso => { %>
                        <option value="<%= curso.id_curso %>"><%= curso.nombre %></option>
                    <% }) %>
                </select>
            </div>
            <button type="submit" class="btn btn-success">Guardar leccion</button>
        </form>
    </div>
</div>
<%- include('../partials/footer') %>
</body>
</html>
